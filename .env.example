# Cathedral Orchestrator — Environment Configuration
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: local fallback model endpoint
LOCAL_MODEL_URL=http://localhost:8080/v1

# Cathedral paths
COVENANT_PATH=~/cathedral/COVENANT.json
AUDIT_LOG_PATH=~/cathedral/audit.log
ARCHIVE_PATH=~/cathedral/archive/
SESSION_PATH=~/cathedral/sessions/

# Logging
LOG_LEVEL=INFO
